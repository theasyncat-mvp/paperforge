{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Paperforge",
  "version": "0.1.0",
  "identifier": "com.asyncat.paperforge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Paperforge",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQxQjc0QzY3NTI1OTJDNTAKUldSUUxGbFNaMHkzMGVoclpPUytXWTlQYUtqZ1h3OVFkditEUnhSbG5ZM25mdWYzdHlBek1MRTIK",
      "endpoints": [
        "https://github.com/Jeevash23/paperforge/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
